# **************************************************************************** #
#                                    Colors                                    #
# **************************************************************************** #

C_STD = \033[0;39m
C_GRAY = \033[0;90m
C_RED = \033[0;91m
C_GREEN = \033[0;92m
C_YELLOW = \033[0;93m
C_BLUE = \033[0;94m
C_MAGENTA = \033[0;95m
C_CYAN = \033[0;96m
C_WHITE = \033[0;97m

# **************************************************************************** #
#                                    Names                                     #
# **************************************************************************** #

NAME		= phone_book

# **************************************************************************** #
#                                    Path's                                    #
# **************************************************************************** #

SRC_PATH	= src/
BUILD_PATH	= .build/
INC_PATH	= include/

VPATH		= ./

# **************************************************************************** #
#                                    Files                                     #
# **************************************************************************** #

FILES		+=	main

SRCS		= $(addprefix ./, $(addsuffix .cpp, $(FILES)))
OBJS		= $(addprefix $(BUILD_PATH), $(addsuffix .o, $(FILES)))

# **************************************************************************** #
#                                  Compiler                                    #
# ***************************************make_libft************************************* #

VERSION		= -std=c++98
CC			= c++ $(VERSION)
CFLAGS		= -Wall -Wextra -Werror
MAKE		= make --no-print-directory
RM			= rm -rf

# **************************************************************************** #
#                                    Comands                                   #
# **************************************************************************** #


all: start $(NAME)
	@printf "$(C_MAGENTA)===========End [$(NAME)]===========$(C_STD)\n"

start:
	@printf "$(C_MAGENTA)===========Program [$(NAME)]===========$(C_STD)\n"

$(NAME): $(BUILD_PATH) $(OBJS)
	@$(CC) $(CFLAGS) -I$(INC_PATH) $(OBJS) -o $(NAME)

$(BUILD_PATH)%.o: %.cpp
	@$(CC) $(CFLAGS) -c $< -o $@
	@printf "$(C_YELLOW)Compiling $< -> $@$(C_STD)\n";

$(BUILD_PATH):
	@mkdir -p $(BUILD_PATH)

clean:
	@$(RM) $(BUILD_PATH)

fclean: clean
	@$(RM) $(NAME)

re: fclean all